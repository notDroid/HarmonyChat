APP_ENV="development"
CONSUMER_NAME="Harmony CDC Worker Local"
FEATURES__CACHE_REDIS="True"

# Connection Strings
POSTGRES__URL="postgresql+asyncpg://harmony:harmony@postgres:5432/harmony"
REDIS__URL="redis://redis:6379/1"
DYNAMODB__URL="http://dynamodb:8000"
KAFKA_CONSUMER__BOOTSTRAP_SERVERS="kafka:29092"