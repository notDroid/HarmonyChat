### Non-secret configuration for infrastructure components

# Postgres
POSTGRES_USER={{ infra.postgres.user }}
POSTGRES_DB={{ infra.postgres.dbname }}

# AWS
AWS_REGION={{ infra.aws.region }}

# API
API_ENDPOINT="http://{{ workloads.api.host }}:{{ workloads.api.port }}"

# Kafka
KAFKA_FULLNAME={{ infra.kafka.host }}:{{ infra.kafka.port }}
KAFKA_CLUSTER_ID={{ infra.kafka.cluster_id }}
KAFKA_S3_DATA_URL="s3://{{ infra.s3.buckets.automq_data }}?region={{ infra.s3.region }}&endpoint={{ infra.s3.endpoint }}&pathStyle={{ infra.s3.path_style }}"
KAFKA_S3_OPS_URL="s3://{{ infra.s3.buckets.automq_ops }}?region={{ infra.s3.region }}&endpoint={{ infra.s3.endpoint }}&pathStyle={{ infra.s3.path_style }}"

# DynamoDB
DYNAMODB_ENDPOINT="http://{{ infra.dynamodb.host }}:{{ infra.dynamodb.port }}"

# S3
S3_ENDPOINT={{ infra.s3.endpoint }}
S3_REGION={{ infra.s3.region }}
S3_AUTOMQ_DATA_BUCKET={{ infra.s3.buckets.automq_data }}
S3_AUTOMQ_OPS_BUCKET={{ infra.s3.buckets.automq_ops }}

### Secrets

# App
APP_SECRET_KEY={{ secrets.app.secret_key }}

# Postgres
POSTGRES_PASSWORD={{ secrets.postgres.password }}
POSTGRES_URL="postgresql+asyncpg://{{ infra.postgres.user }}:{{ secrets.postgres.password }}@{{ infra.postgres.host }}:{{ infra.postgres.port }}/{{ infra.postgres.dbname }}"

# AWS
AWS_ACCESS_KEY_ID={{ secrets.aws.access_key_id }}
AWS_SECRET_ACCESS_KEY={{ secrets.aws.secret_access_key }}

# S3
S3_ACCESS_KEY={{ secrets.s3.access_key }}
S3_SECRET_KEY={{ secrets.s3.secret_key }}

# Centrifugo
CENTRIFUGO_API_KEY={{ secrets.centrifugo.api_key }}
CENTRIFUGO_ADMIN_PASSWORD={{ secrets.centrifugo.admin_password }}
CENTRIFUGO_ADMIN_SECRET={{ secrets.centrifugo.admin_secret }}