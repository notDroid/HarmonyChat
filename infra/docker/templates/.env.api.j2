APP_ENV="{{ app_env }}"
FEATURES__CACHE_REDIS="True"

POSTGRES__URL="postgresql+asyncpg://{{ postgres.user }}:{{ postgres.password }}@{{ postgres.hostname }}:{{ postgres.port }}/{{ postgres.dbname }}"
REDIS__URL="redis://{{ redis.address }}/1"
DYNAMODB__URL="{{ dynamodb.endpoint }}"
KAFKA_PRODUCER__BOOTSTRAP_SERVERS="{{ kafka.brokers }}"