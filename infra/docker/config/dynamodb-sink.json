{
  "name": "dynamodb-chat-sink",
  "config": {
    "connector.class": "io.confluent.connect.aws.dynamodb.DynamoDbSinkConnector",
    "tasks.max": "1",
    "topics": "chat_messages",
    "aws.dynamodb.endpoint": "http://dynamodb:8000",
    "aws.dynamodb.region": "us-east-1",
    "table.name.format": "ChatHistory",
    "aws.credentials.provider.class": "com.amazonaws.auth.EnvironmentVariableCredentialsProvider",

    "confluent.topic.bootstrap.servers": "kafka:29092",
    "confluent.topic.replication.factor": "1",

    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "transforms": "StripAuthorMetadata",
    "transforms.StripAuthorMetadata.type": "org.apache.kafka.connect.transforms.ReplaceField$Value",
    "transforms.StripAuthorMetadata.exclude": "author_metadata"
  }
}