{
  "consumers": [
    {
      "name": "chat_kafka_consumer",
      "type": "kafka",
      "enabled": true,
      "kafka": {
        "brokers": ["kafka:29092"],
        ...
      }
    }
  ],
  "engine": {
    "type": "redis",
    "redis": {
      "address": "redis:6379",
      "prefix": "centrifugo"
    }
  },
  "http_api": {
    "key": "test-cent-api-key"
  },
  "admin": {
    "password": "admin",
    "secret": "admin"
  },
  "client": {
    "allowed_origins": ["*"],
    "proxy": {
      "connect": {
        "enabled": true,
        "endpoint": "http://api:8000/api/v1/ws/connect",
        "timeout": "1s",
        "http_headers": ["Cookie"]
      }
    }
  },
  "channel": {
    "namespaces": [
      {
        "name": "chat",
        "subscribe_proxy_enabled": true,
        "presence": true,
        "history_size": 100,
        "history_ttl": "3600s"
      }
    ],
    "proxy": {
      "subscribe": {
        "endpoint": "http://api:8000/api/v1/ws/subscribe",
        "timeout": "1s"
      }
    }
  }
}