# secrets.yaml.example
#
# Copy this to secrets.yaml (gitignored) and fill in real values.
# Pass to helmfile with: helmfile -f helmfile.yaml -f secrets.yaml apply
#
# In production, prefer sealed-secrets, AWS Secrets Manager, or Vault instead.

# --- PostgreSQL ---
# postgresql:
#   auth:
#     password: <strong-password>

# --- Backend / Consumer ---
# backend:
#   env:
#     postgres:
#       url: "postgresql+asyncpg://harmony:<password>@<host>:5432/harmony"
#     aws:
#       accessKeyId: "<real-key>"
#       secretAccessKey: "<real-secret>"

# consumer:
#   env:
#     postgres:
#       url: "postgresql+asyncpg://harmony:<password>@<host>:5432/harmony"
#     aws:
#       accessKeyId: "<real-key>"
#       secretAccessKey: "<real-secret>"

