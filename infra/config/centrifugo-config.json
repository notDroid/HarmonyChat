{
  "consumers": [
    {
      "name": "chat_kafka_consumer",
      "type": "kafka",
      "enabled": true,
      "kafka": {
        "brokers": ["kafka:9092"],
        "topics": ["chat_messages"],
        "consumer_group": "centrifugo",
        "publication_data_mode": {
          "enabled": true
        }
      }
    }
  ],
  "engine": {
    "type": "redis",
    "redis": {
      "address": "redis:6379",
      "prefix": "centrifugo"
    }
  },
  "http_api": {
    "key": "your-secure-backend-api-key"
  },
  "admin": {
    "password": "admin",
    "secret": "admin"
  },
  "client": {
    "allowed_origins": [
      "*"
    ],
    "proxy": {
      "connect": {
        "enabled": true, 
        "endpoint": "http://api:8000/api/v1/ws/connect",
        "timeout": "1s",
        "http_headers": [
          "Cookie"
        ]
      }
    }
  },
  "channel": {
    "namespaces": [
      {
        "name": "chat",
        "subscribe_proxy_enabled": true,
        "presence": true,
        "history_size": 50,
        "history_ttl": "24h"
      }
    ],
    "proxy": {
      "subscribe": {
        "endpoint": "http://api:8000/api/v1/ws/subscribe",
        "timeout": "1s"
      }
    }
  }
}