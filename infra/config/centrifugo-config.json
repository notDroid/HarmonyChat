{
  "engine": "redis",
  "redis_address": "redis:6379",
  "redis_prefix": "centrifugo",

  "api_key": "your-secure-backend-api-key",

  "allowed_origins": [
    "*" 
  ],

  "proxy_connect_endpoint": "http://api:8000/api/v1/ws/connect",
  "proxy_connect_timeout": "2s",
  "proxy_connect_http_headers": ["Cookie"],
  
  "proxy_subscribe_endpoint": "http://api:8000/api/v1/ws/subscribe",
  "proxy_subscribe_timeout": "2s",

  "namespaces": [
    {
      "name": "chat",
      "proxy_subscribe": true,
      "presence": true,
      "history_size": 50,
      "history_ttl": "24h"
    }
  ],

  "admin": true,
  "admin_password": "admin",
  "admin_secret": "admin"
}