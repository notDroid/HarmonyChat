{
  "engine": "redis",
  "redis_address": "redis:6379",
  "redis_prefix": "centrifugo",

  "api_key": "your-secure-backend-api-key",

  "allowed_origins": [
    "*" 
  ],
  "allow_anonymous": true,

  "namespaces": [
    {
      "name": "chat",
      "subscribe_proxy_name": "fastapi_proxy"
    }
  ],

  "proxies": [
    {
      "name": "fastapi_proxy",
      "endpoint": "http://api:8000/api/v1/centrifugo/subscribe"
    }
  ],

  "admin": {
    "enabled": true,
    "password": "admin",
    "secret": "admin"
  }
}