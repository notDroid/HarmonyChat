APP_ENV="{{ app.env }}"
CONSUMER_NAME="{{ app.consumer.name }}"
FEATURES__CACHE_REDIS="True"

POSTGRES__URL="postgresql+asyncpg://{{ infra.postgres.user }}:{{ infra.postgres.password }}@{{ infra.postgres.host }}:{{ infra.postgres.port }}/{{ infra.postgres.dbname }}"
REDIS__URL="redis://{{ infra.redis.host }}:{{ infra.redis.port }}/1"
DYNAMODB__URL="http://{{ infra.dynamodb.host }}:{{ infra.dynamodb.port }}"
KAFKA_CONSUMER__BOOTSTRAP_SERVERS="{{ infra.kafka.client_host | default(infra.kafka.host) }}:{{ infra.kafka.port }}"