{
  "consumers": [
    {
      "name": "chat_kafka_consumer",
      "type": "kafka",
      "enabled": true,
      "kafka": {
        "brokers": ["{{ infra.kafka.client_host | default(infra.kafka.host) }}:{{ infra.kafka.port }}"],
        "topics": ["{{ infra.kafka.topics.chat_messages }}"],
        "consumer_group": "centrifugo",
        "publication_data_mode": {
          "enabled": true,
          "channels_header": "x-centrifugo-channels" 
        }
      }
    }
  ],
  "engine": {
    "type": "redis",
    "redis": {
      "address": "redis://{{ infra.redis.host }}:{{ infra.redis.port }}",
      "prefix": "centrifugo"
    }
  },
  "http_api": {
    "key": "{{ infra.centrifugo.api_key }}"
  },
  "admin": {
    "password": "{{ infra.centrifugo.admin_password }}",
    "secret": "{{ infra.centrifugo.admin_secret }}"
  },
  "client": {
    "allowed_origins": {{ infra.centrifugo.allowed_origins | tojson }},
    "proxy": {
      "connect": {
        "enabled": true,
        "endpoint": "http://{{ workloads.api.host }}:{{ workloads.api.port }}/api/v1/ws/connect",
        "timeout": "1s",
        "http_headers": ["Cookie"]
      }
    }
  },
  "channel": {
    "namespaces": [
      {
        "name": "chat",
        "subscribe_proxy_enabled": true,
        "presence": {{ infra.centrifugo.chat.presence_enabled | tojson }},
        "history_size": {{ infra.centrifugo.chat.history_size }},
        "history_ttl": {{ infra.centrifugo.chat.history_ttl | tojson }}
      }
    ],
    "proxy": {
      "subscribe": {
        "endpoint": "http://{{ workloads.api.host }}:{{ workloads.api.port }}/api/v1/ws/subscribe",
        "timeout": "1s"
      }
    }
  }
}