# ==========================================
# App Metadata
# ==========================================
CONSUMER_NAME="Harmony CDC Worker"
APP_ENV="development" # Options: development, staging, production

# ==========================================
# Feature Toggles
# ==========================================
FEATURES__CACHE_REDIS="False"

# ==========================================
# Infrastructure: Redis (Cache Invalidation)
# ==========================================
REDIS__URL="redis://localhost:6379/1"
REDIS__HEALTH_CHECK_INTERVAL="30"
REDIS__REQUEST_TIMEOUT_MS="100"

# ==========================================
# Infrastructure: PostgreSQL (Source of Truth)
# ==========================================
POSTGRES__URL="postgresql+asyncpg://user:password@localhost:5432/harmony"

# ==========================================
# Infrastructure: AWS & DynamoDB
# ==========================================
AWS__REGION="us-east-1"
AWS__DEFAULT_REGION="us-east-1"
AWS__ACCESS_KEY_ID="test"
AWS__SECRET_ACCESS_KEY="test"

DYNAMODB__URL="http://localhost:8080"
DYNAMODB__CHAT_HISTORY_TABLE_NAME="ChatHistory"

# ==========================================
# Infrastructure: Kafka Consumer (CDC Worker)
# ==========================================
KAFKA_CONSUMER__BOOTSTRAP_SERVERS="localhost:9092"
KAFKA_CONSUMER__GROUP_ID="harmony-cdc-worker"
KAFKA_CONSUMER__TOPICS='["Chat", "User"]'
KAFKA_CONSUMER__MAX_POLL_RECORDS="500"
KAFKA_CONSUMER__FETCH_MAX_BYTES="52428800"
KAFKA_CONSUMER__SESSION_TIMEOUT_MS="10000"
KAFKA_CONSUMER__POLL_TIMEOUT_MS="1000"